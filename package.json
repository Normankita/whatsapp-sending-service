    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.0",
    "whatsapp-web.js": "^1.23.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
