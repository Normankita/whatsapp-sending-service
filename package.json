{
  "name": "harusi-backend",
  "version": "1.0.0",
  "description": "WhatsApp bulk sender for wedding cards",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "render-build": "npm install && npx puppeteer browsers install chrome",
    "docker:build": "docker build -t harusi-backend .",
